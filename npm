#!/bin/bash

machine=$(uname -m)
case "$machine" in

    x86_64)
        dockerImage="guzo/npm"
        ;;

    armv7l)
        dockerImage="guzo/npm:rpi"
        ;;

    *)
        echo "Unsupported architecture: $machine"
        exit 1
        ;;
esac

targetDir="/usr/src/npm"
if [[ "$1" == "bash" ]] ; then
    docker run -ti --name npm --hostname npm --user ian -e "HOME=/home/ian" -e "TERM=xterm-256color" -v $PWD:$targetDir -w $targetDir $dockerImage bash
else
    docker run -ti --name npm --hostname npm --user ian -e "HOME=/home/ian" -e "TERM=xterm-256color" -v $PWD:$targetDir -w $targetDir $dockerImage npm $*
fi
docker rm npm
